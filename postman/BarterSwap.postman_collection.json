{
  "info": {
    "_postman_id": "b4rt3rsw4p-d3m0-c0ll3ct10n",
    "name": "BarterSwap — Démo soutenance",
    "description": "Parcours complet pour la soutenance (≈5 min) : utilisateurs, compétences, service, échange (accept/complete), avis, statistiques, puis quelques cas d'erreur représentatifs. Chaque requête de création renseigne automatiquement les variables de collection (alice_id, bob_id, service_id, exchange_id) utilisées par les requêtes suivantes : il suffit de dérouler la collection de haut en bas, ou de lancer le Collection Runner.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "alice_id", "value": "" },
    { "key": "bob_id", "value": "" },
    { "key": "service_id", "value": "" },
    { "key": "exchange_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Utilisateurs & compétences",
      "item": [
        {
          "name": "Créer Alice",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('alice_id', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pseudo\": \"alice\",\n  \"bio\": \"Prof de guitare\",\n  \"ville\": \"Lyon\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Créer Bob",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('bob_id', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pseudo\": \"bob\",\n  \"bio\": \"Bricoleur du dimanche\",\n  \"ville\": \"Lyon\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Bob renseigne sa compétence (Bricolage)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{bob_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"nom\": \"Bricolage\", \"niveau\": \"expert\" }\n]",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/users/{{bob_id}}/skills", "host": ["{{base_url}}"], "path": ["api", "users", "{{bob_id}}", "skills"] }
          }
        },
        {
          "name": "Consulter le profil de Bob",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/users/{{bob_id}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{bob_id}}"] }
          }
        }
      ]
    },
    {
      "name": "2. Services",
      "item": [
        {
          "name": "Bob publie un service (Bricolage, 4 crédits)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('service_id', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{bob_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Montage de meuble IKEA\",\n  \"description\": \"Je monte votre meuble en moins d'une heure\",\n  \"categorie\": \"Bricolage\",\n  \"duree_minutes\": 60,\n  \"credits\": 4,\n  \"ville\": \"Lyon\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/services", "host": ["{{base_url}}"], "path": ["api", "services"] }
          }
        },
        {
          "name": "Rechercher par catégorie + ville",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/services?categorie=Bricolage&ville=Lyon",
              "host": ["{{base_url}}"],
              "path": ["api", "services"],
              "query": [
                { "key": "categorie", "value": "Bricolage" },
                { "key": "ville", "value": "Lyon" }
              ]
            }
          }
        },
        {
          "name": "Rechercher par mot-clé",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/services?search=meuble",
              "host": ["{{base_url}}"],
              "path": ["api", "services"],
              "query": [{ "key": "search", "value": "meuble" }]
            }
          }
        }
      ]
    },
    {
      "name": "3. Échange (demande → acceptation → complétion)",
      "item": [
        {
          "name": "Alice demande le service de Bob",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('exchange_id', pm.response.json().exchange_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{alice_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service_id\": {{service_id}}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/exchanges", "host": ["{{base_url}}"], "path": ["api", "exchanges"] }
          }
        },
        {
          "name": "Bob accepte (crédits d'Alice bloqués)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "X-User-ID", "value": "{{bob_id}}" }],
            "url": { "raw": "{{base_url}}/api/exchanges/{{exchange_id}}/accept", "host": ["{{base_url}}"], "path": ["api", "exchanges", "{{exchange_id}}", "accept"] }
          }
        },
        {
          "name": "Vérifier le solde d'Alice (10 → 6)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/users/{{alice_id}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{alice_id}}"] }
          }
        },
        {
          "name": "Alice confirme la complétion (crédits transférés à Bob)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "X-User-ID", "value": "{{alice_id}}" }],
            "url": { "raw": "{{base_url}}/api/exchanges/{{exchange_id}}/complete", "host": ["{{base_url}}"], "path": ["api", "exchanges", "{{exchange_id}}", "complete"] }
          }
        },
        {
          "name": "Vérifier le solde de Bob (10 → 14)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/users/{{bob_id}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{bob_id}}"] }
          }
        }
      ]
    },
    {
      "name": "4. Avis & statistiques",
      "item": [
        {
          "name": "Alice laisse un avis sur Bob",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{alice_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": 5,\n  \"commentaire\": \"Rapide et efficace, merci Bob !\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/exchanges/{{exchange_id}}/review", "host": ["{{base_url}}"], "path": ["api", "exchanges", "{{exchange_id}}", "review"] }
          }
        },
        {
          "name": "Avis reçus par Bob",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/users/{{bob_id}}/reviews", "host": ["{{base_url}}"], "path": ["api", "users", "{{bob_id}}", "reviews"] }
          }
        },
        {
          "name": "Statistiques de Bob",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/users/{{bob_id}}/stats", "host": ["{{base_url}}"], "path": ["api", "users", "{{bob_id}}", "stats"] }
          }
        }
      ]
    },
    {
      "name": "5. Cas d'erreur (gestion d'erreurs)",
      "item": [
        {
          "name": "Créer un utilisateur sans pseudo → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"pseudo\": \"\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Modifier le profil d'un autre utilisateur → 401",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{alice_id}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"bio\": \"Je m'incruste chez Bob\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/api/users/{{bob_id}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{bob_id}}"] }
          }
        },
        {
          "name": "Bob s'échange son propre service → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{bob_id}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"service_id\": {{service_id}}\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/api/exchanges", "host": ["{{base_url}}"], "path": ["api", "exchanges"] }
          }
        },
        {
          "name": "Alice note deux fois le même échange → 409",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{alice_id}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"note\": 3,\n  \"commentaire\": \"Nouvelle tentative\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/api/exchanges/{{exchange_id}}/review", "host": ["{{base_url}}"], "path": ["api", "exchanges", "{{exchange_id}}", "review"] }
          }
        }
      ]
    }
  ]
}
